# Получите у @BotFather
BOT_TOKEN=123456789:ABCDEF

# Секрет для подписи сессий WebApp (случайная длинная строка)
SESSION_SECRET=change-me-to-random

# Публичный HTTPS URL, где открывается WebApp (без завершающего /)
# Например https://wheel.example.com или https://xxxx.ngrok-free.app
PUBLIC_BASE_URL=https://your-domain.example

# Путь Telegram webhook (URL будет PUBLIC_BASE_URL + WEBHOOK_PATH)
WEBHOOK_PATH=/telegram/webhook

# Секрет для webhook-заголовка X-Telegram-Bot-Api-Secret-Token
WEBHOOK_SECRET=change-me-webhook-secret

# Числовой id группы/супергруппы (обычно отрицательный), куда слать GIF и где /stat
TARGET_CHAT_ID=-1001234567890

# Telegram user id суперадминов через запятую (узнать у @userinfobot)
SUPERADMIN_IDS=111111111,222222222

# Порт локального HTTP (бот + API + статика WebApp)
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# За nginx/Caddy: иначе возможна ошибка «RFC1918 IP to public server address».
# По умолчанию в коде уже *, при необходимости переопределите (IP прокси через запятую).
# FORWARDED_ALLOW_IPS=*

# Без nginx: HTTPS прямо в Uvicorn (полная цепочка + приватный ключ). Задайте оба или ни одного.
# Пример для Let's Encrypt: fullchain.pem и privkey.pem
# SSL_CERTFILE=C:\certs\kolesosychat.fun-fullchain.pem
# SSL_KEYFILE=C:\certs\kolesosychat.fun-privkey.pem
# Тогда HTTP_PORT часто 443 (на Windows может понадобиться запуск от администратора).

# Необязательно: путь к SQLite (по умолчанию ./data/app.db рядом с проектом)
# DATABASE_PATH=C:\apps\wheel\data\app.db
